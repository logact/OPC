# OPC server 管理面地址
OPC_BASE_URL=http://192.168.1.51:3000
# MQTT broker 地址
OPC_BROKER_URL=mqtt://192.168.1.51:1883
# 所有 agent 加入的房间（需预先通过 HTTP API 创建）
OPC_ROOM_ID=
# agent 列表（JSON）。engine: shell | kimi | claude-code
OPC_AGENTS='[{"id":"agent1","name":"Agent 1","engine":"kimi"},{"id":"agent2","name":"Agent 2","engine":"shell"}]'
# 无 @提及 时默认接收消息的 agent
OPC_DEFAULT_AGENT=agent1
# 本地数据目录（memory store、.agents.json 凭据）
OPC_DATA_DIR=./data
# MQTT 重连间隔（ms）
OPC_RECONNECT_PERIOD_MS=5000

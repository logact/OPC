{
  "name": "@opc/server",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch --preserveWatchOutput & node --watch dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opc/core": "workspace:*",
    "@opc/database": "workspace:*",
    "@opc/protocol": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0"
  }
}

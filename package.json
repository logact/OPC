{
  "name": "opc",
  "version": "1.2.3",
  "private": true,
  "description": "OPC monorepo: server, mobile client, and shared packages",
  "type": "module",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @opc/server dev",
    "dev:mobile": "pnpm --filter @opc/mobile start",
    "mobile:android": "pnpm --filter @opc/mobile android",
    "mobile:ios": "pnpm --filter @opc/mobile ios",
    "db:generate": "pnpm --filter @opc/database db:generate",
    "db:migrate": "pnpm --filter @opc/database db:migrate",
    "db:push": "pnpm --filter @opc/database db:push",
    "db:studio": "pnpm --filter @opc/database db:studio",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:mobile": "pnpm --filter @opc/mobile test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}

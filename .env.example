# 生产环境部署配置（复制为 .env 后按需修改）
# 此文件仅作示例，真实 .env 应放在服务器部署目录，切勿提交到仓库

# OPC Server HTTP 端口
PORT=3000

# PostgreSQL 连接串
# 未设置时，docker-compose.prod.yml 会自动根据下方 POSTGRES_* 变量拼接，
# 避免密码不一致导致迁移/服务连接失败。如需使用外部数据库，可显式配置。
# DATABASE_URL=postgres://opc:change-me-to-a-strong-password@postgres:5432/opc

# MQTT broker 地址（生产环境使用 compose 服务名）
MQTT_BROKER_URL=mqtt://mosquitto:1883

# broker superuser 凭据，server 自身连接 broker 时使用
MQTT_SERVER_USERNAME=__server__
MQTT_SERVER_PASSWORD=change-me-to-a-strong-password

# PostgreSQL 初始化凭据
POSTGRES_USER=opc
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=opc

# MQTT broker 宿主机映射端口
MQTT_PORT=1883

# 生产部署时由 CI 注入，指向刚构建的 server 镜像
SERVER_IMAGE=ghcr.io/logact/opc-server:master
